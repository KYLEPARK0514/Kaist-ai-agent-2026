            ]
          },
          "vectorEmbeddingPolicy": {
            "vectorEmbeddings": [
              {
                "path": "/embedding",
                "dataType": "float32",
                "dimensions": 1536,
                "distanceFunction": "cosine"
              }
            ]
          },
          "fullTextPolicy": {
            "defaultLanguage": "en-US",
            "fullTextPaths": [
              {
                "path": "/content",
                "language": "en-US"
              }
            ]
          }
        }
